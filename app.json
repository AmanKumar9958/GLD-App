{
  "expo": {
    "name": "GLD Institute",
    "slug": "GLD-Institute",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gldinstitute",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.solostackdev.gldinstitute"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.solostackdev.gldinstitute",
      "versionCode": 5,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#F0F4FB",
          "dark": {
            "backgroundColor": "#0B1220"
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "googleWebClientId": "444382898641-dcacsmeqtdn3o7j09tu3ei764l2ia7qu.apps.googleusercontent.com",
      "eas": {
        "projectId": "a91fd320-9cba-450a-ba8c-6a26787bbd64"
      }
    }
  }
}